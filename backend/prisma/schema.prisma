generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ==================== SHARED ENUMS ====================

enum Board {
  STATE
  CBSE
  IGCSE
  IB
}

// ==================== SUPER ADMIN & PLATFORM ====================

model SuperAdmin {
  id              String    @id @default(uuid())
  name            String
  email           String    @unique
  password        String
  phone           String?
  twoFAEnabled    Boolean   @default(true)
  twoFASecret     String?
  role            String    @default("SuperAdmin")
  lastLogin       DateTime?
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  AuditLogs       AuditLog[] @relation("SuperAdminAuditLogs")
}

// College Domain Management
model CollegeDomain {
  id              String    @id @default(uuid())
  domain          String    @unique
  collegeName     String
  isPrimary       Boolean   @default(false)
  status          String    @default("pending") // pending, active, inactive
  sslEnabled      Boolean   @default(false)
  dnsVerified     Boolean   @default(false)
  dnsToken        String?
  approvedBy      String?
  approvedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([collegeId, domain])
}

// ==================== COLLEGE & SUBSCRIPTION ====================

model College {
  id              String    @id @default(uuid())
  name            String
  description     String?
  email           String?
  phone           String?
  address         String?
  city            String?
  state           String?
  country         String?
  pincode         String?
  logo            String?
  favicon         String?
  theme           String    @default("blue")
  footerText      String?
  status          String    @default("active") // active, suspended, inactive
  whiteLabel      Boolean   @default(true)
  maxUsers        Int       @default(10000)
  storageLimit    Int       @default(100) // in GB
  storageUsed     Int       @default(0) // in GB
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Subscription
  subscriptionPlan String  @default("starter") // starter, professional, enterprise
  subscriptionStartDate DateTime?
  subscriptionEndDate DateTime?
  isSubscriptionActive Boolean @default(true)

  // Relations
  Domains         CollegeDomain[]
  Users           User[]
  Sclasses        Sclass[]
  Subjects        Subject[]
  Teachers        Teacher[]
  Students        Student[]
  Parents         Parent[]
  Notices         Notice[]
  Complains       Complain[]
  Admissions      Admission[]
  Fees            Fee[]
  Payments        Payment[]
  Exams           Exam[]
  Results         ExamResult[]
  Attendances     Attendance[]
  Routes          BusRoute[]
  Buses           Bus[]
  TransportFees   TransportFee[]
  Homework        Homework[]
  AuditLogs       AuditLog[]
  Admins          Admin[]
  AdmissionTeams  AdmissionTeam[]
  AccountsTeams   AccountsTeam[]
  TransportTeams  TransportTeam[]
  Sections        Section[]
  TeacherAttendances TeacherAttendance[]
  TeacherSectionAssignments TeacherSectionAssignment[]
}

// ==================== USER & ROLES ====================

model Role {
  id              String    @id @default(uuid())
  name            String    // SuperAdmin, CollegeAdmin, Teacher, Student, Parent, etc.
  description     String?
  permissions     String[]  // JSON array of permissions
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}

model User {
  id              String    @id @default(uuid())
  name            String
  email           String?
  phone           String?
  password        String
  profileImage    String?
  role            String    // SuperAdmin, Admin, Teacher, Student, Parent, AdmissionTeam, AccountsTeam, TransportTeam
  roleId          String?
  
  // Multi-tenancy
  collegeId       String?
  college         College?  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  // Authentication
  isEmailVerified Boolean   @default(false)
  isPhoneVerified Boolean   @default(false)
  twoFAEnabled    Boolean   @default(false)
  twoFASecret     String?
  lastLogin       DateTime?
  lastLoginIP     String?
  
  // Status
  isActive        Boolean   @default(true)
  isDeleted       Boolean   @default(false)
  
  metadata        Json?     // Store additional role-specific data
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  // Role-specific relations
  AdminProfile    Admin?
  TeacherProfile  Teacher?
  StudentProfile  Student?
  ParentProfile   Parent?
  AdmissionTeamProfile AdmissionTeam?
  AccountsTeamProfile  AccountsTeam?
  TransportTeamProfile TransportTeam?

  AuditLogs       AuditLog[]
  OTPLogs         OTPLog[]

  @@unique([email, collegeId])
  @@index([collegeId])
  @@index([role])
}

// ==================== COLLEGE ADMIN ====================

model Admin {
  id              String    @id @default(uuid())
  name            String
  email           String
  password        String
  phone           String?
  profileImage    String?
  role            String    @default("Admin")
  designation     String?
  department      String?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
  @@index([email])
}

// ==================== TEAM ROLES ====================

model AdmissionTeam {
  id              String    @id @default(uuid())
  name            String
  email           String
  phone           String?
  profileImage    String?
  designation     String?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  Admissions      Admission[]
  
  @@index([collegeId])
}

model AccountsTeam {
  id              String    @id @default(uuid())
  name            String
  email           String
  phone           String?
  profileImage    String?
  designation     String?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  Payments        Payment[]
  
  @@index([collegeId])
}

model TransportTeam {
  id              String    @id @default(uuid())
  name            String
  email           String
  phone           String?
  profileImage    String?
  designation     String?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
}

// ==================== ACADEMIC ====================

model Sclass {
  id              String    @id @default(uuid())
  sclassName      String
  sclassCode      String?
  academicYear    String?
  sectionCount    Int       @default(1)
  description     String?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  classTeacherId  String?
  classTeacher    Teacher?  @relation("ClassTeacher", fields: [classTeacherId], references: [id])

  Subjects        Subject[]
  Students        Student[]
  Sections        Section[]
  Exams           Exam[]
  TeacherSectionAssignments TeacherSectionAssignment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
}

model Section {
  id              String    @id @default(uuid())
  sectionName     String
  capacity        Int       @default(60)
  
  sclassId        String
  sclass          Sclass    @relation(fields: [sclassId], references: [id], onDelete: Cascade)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  Students        Student[]
  TeacherSectionAssignments TeacherSectionAssignment[]
  Homework        Homework[]

  @@index([sclassId])
  @@index([collegeId])
}

model Subject {
  id              String    @id @default(uuid())
  subName         String
  subCode         String
  description     String?
  creditHours     Int?
  maxMarks        Int       @default(100)
  passingMarks    Int       @default(40)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  sclassId        String
  sclass          Sclass    @relation(fields: [sclassId], references: [id], onDelete: Cascade)

  teacherId       String?
  teacher         Teacher?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  ExamResults     ExamResult[]
  Attendances     Attendance[]
  Homeworks       Homework[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([collegeId, sclassId, subCode])
  @@index([sclassId])
  @@index([teacherId])
}

model Teacher {
  id              String    @id @default(uuid())
  name            String
  email           String
  phone           String?
  password        String
  profileImage    String?
  dateOfBirth     DateTime?
  gender          String?
  qualification   String?
  experience      Int?
  specialization  String?
  employeeId      String?

  collegeId       String
  college         College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Class teacher assignment
  ClassTeacherOf  Sclass[]  @relation("ClassTeacher")

  Subjects        Subject[]
  Attendances     TeacherAttendance[]
  Homeworks       Homework[]
  Complaints      Complain[]
  SectionAssignments TeacherSectionAssignment[]

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
}

model TeacherSectionAssignment {
  id          String   @id @default(uuid())

  teacherId   String
  teacher     Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  sclassId    String
  sclass      Sclass   @relation(fields: [sclassId], references: [id], onDelete: Cascade)

  sectionId   String
  section     Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  collegeId   String
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())

  @@unique([teacherId, sectionId])
  @@index([teacherId])
  @@index([sclassId])
  @@index([sectionId])
  @@index([collegeId])
}

model TeacherAttendance {
  id              String    @id @default(uuid())
  date            DateTime
  status          String    // present, absent, leave
  leaveType       String?
  remarks         String?

  teacherId       String
  teacher         Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([collegeId])
}

model Student {
  id              String    @id @default(uuid())
  name            String
  studentId       String    // Custom student ID
  rollNum         Int?
  email           String?
  phone           String?
  password        String
  dateOfBirth     DateTime?
  gender          String?
  parentName      String?
  parentPhone     String?
  profileImage    String?
  board           Board?
  integratedCourse String?
  group           String?
  admissionYear   Int?
  admissionNumber String?
  customClassName String?   // Manual class entry
  customSectionName String? // Manual section entry

  collegeId       String
  college         College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  sclassId        String?
  sclass          Sclass?   @relation(fields: [sclassId], references: [id], onDelete: Cascade)

  sectionId       String?
  section         Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  parentId        String?
  parent          Parent?  @relation(fields: [parentId], references: [id], onDelete: SetNull)

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  busRouteId      String?
  busRoute        BusRoute? @relation(fields: [busRouteId], references: [id], onDelete: SetNull)

  isActive        Boolean   @default(true)
  isDeleted       Boolean   @default(false)

  ExamResults     ExamResult[]
  Attendances     Attendance[]
  Complaints      Complain[]
  Fees            Fee[]
  Payments        Payment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([collegeId, studentId])
  @@unique([collegeId, email])
  @@index([sclassId])
  @@index([parentId])
}

// ==================== PARENTS ====================

model Parent {
  id              String    @id @default(uuid())
  name            String
  email           String?
  phone           String
  password        String
  profileImage    String?
  relation        String?   // Father, Mother, Guardian
  occupation      String?
  address         String?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  userId          String    @unique
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  Students        Student[]
  Payments        Payment[]
  Complaints      Complain[]

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([collegeId, phone])
  @@index([collegeId])
  @@index([phone])
}

// ==================== ADMISSIONS ====================

model Admission {
  id              String    @id @default(uuid())
  admissionNumber String    @unique
  applicantName   String
  applicantEmail  String
  applicantPhone  String
  dateOfBirth     DateTime?
  gender          String?
  fatherName      String?
  motherName      String?
  address         String?
  previousSchool  String?
  previousGrade   String?
  documents       Json?     // Array of document URLs
  status          String    @default("pending") // pending, approved, rejected, enrolled
  appliedFor      String?   // which class/grade
  appliedDate     DateTime  @default(now())
  approvedDate    DateTime?
  rejectionReason String?
  comments        String?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  admissionTeamId String?
  admissionTeam   AdmissionTeam? @relation(fields: [admissionTeamId], references: [id], onDelete: SetNull)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
  @@index([status])
}

// ==================== EXAMS & RESULTS ====================

model Exam {
  id              String    @id @default(uuid())
  examName        String
  examCode        String?
  description     String?
  examType        String    @default("offline") // offline, online
  totalMarks      Int       @default(100)
  passingMarks    Int       @default(40)
  examDate        DateTime?
  startTime       String?
  endTime         String?
  duration        Int?      // in minutes
  isPublished     Boolean   @default(false)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  sclassId        String
  sclass          Sclass    @relation(fields: [sclassId], references: [id], onDelete: Cascade)

  ExamResults     ExamResult[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
  @@index([sclassId])
}

model ExamResult {
  id              String    @id @default(uuid())
  marksObtained   Float     @default(0)
  percentage      Float?
  grade           String?
  remarks         String?
  isAbsent        Boolean   @default(false)

  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId       String
  subject         Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  examId          String
  exam            Exam      @relation(fields: [examId], references: [id], onDelete: Cascade)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([studentId, subjectId, examId])
  @@index([studentId])
  @@index([examId])
}

// ==================== ATTENDANCE ====================

model Attendance {
  id              String    @id @default(uuid())
  date            DateTime
  status          String    // present, absent, leave, sick
  remarks         String?

  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId       String
  subject         Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([subjectId])
  @@index([date])
}

// ==================== NOTICES & COMPLAINTS ====================

model Notice {
  id              String    @id @default(uuid())
  title           String
  description     String
  details         String?
  category        String?   // General, Academic, Event, Holiday
  priority        String    @default("normal") // low, normal, high
  attachments     String[]
  publishedDate   DateTime  @default(now())

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdBy       String?
  isActive        Boolean   @default(true)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
}

model Complain {
  id              String    @id @default(uuid())
  title           String
  description     String
  category        String?   // Academic, Behavioral, Facilities, etc.
  status          String    @default("pending") // pending, resolved, rejected
  priority        String    @default("normal") // low, normal, high
  attachments     String[]
  adminResponse   String?
  resolvedDate    DateTime?

  studentId       String?
  student         Student?  @relation(fields: [studentId], references: [id], onDelete: SetNull)

  teacherId       String?
  teacher         Teacher?  @relation(fields: [teacherId], references: [id], onDelete: SetNull)

  parentId        String?
  parent          Parent?   @relation(fields: [parentId], references: [id], onDelete: SetNull)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
  @@index([status])
}

// ==================== HOMEWORK ====================

model Homework {
  id              String    @id @default(uuid())
  title           String
  description     String?
  dueDate         DateTime
  instructions    String?
  attachments     String[]
  totalMarks      Int?

  teacherId       String
  teacher         Teacher   @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  subjectId       String
  subject         Subject   @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  sectionId       String?
  section         Section?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([teacherId])
  @@index([subjectId])
  @@index([sectionId])
}

// ==================== FINANCE ====================

model Fee {
  id              String    @id @default(uuid())
  feeType         String    // tuition, transport, hostel, exam, etc.
  feeCategory     String?
  amount          Float
  dueDate         DateTime
  frequency       String    @default("yearly") // yearly, monthly, one-time
  description     String?
  isActive        Boolean   @default(true)

  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  Payments        Payment[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([studentId])
  @@index([collegeId])
}

model Payment {
  id              String    @id @default(uuid())
  transactionId   String    @unique
  paymentMethod   String    // razorpay, bank_transfer, cash, check
  amount          Float
  status          String    @default("pending") // pending, completed, failed, refunded
  paymentDate     DateTime?
  receiptNumber   String?
  notes           String?

  studentId       String
  student         Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)

  parentId        String?
  parent          Parent?   @relation(fields: [parentId], references: [id], onDelete: SetNull)

  feeId           String?
  fee             Fee?      @relation(fields: [feeId], references: [id], onDelete: SetNull)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  accountsTeamId  String?
  accountsTeam    AccountsTeam? @relation(fields: [accountsTeamId], references: [id], onDelete: SetNull)

  // Razorpay details
  razorpayOrderId String?
  razorpayPaymentId String?
  razorpaySignature String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([studentId])
  @@index([collegeId])
  @@index([status])
}

// ==================== TRANSPORT ====================

model BusRoute {
  id              String    @id @default(uuid())
  routeName       String
  routeNumber     String    @unique
  startPoint      String
  endPoint        String
  distance        Float?
  estimatedTime   String?
  stopsCount      Int?
  fee             Float
  description     String?
  isActive        Boolean   @default(true)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  Buses           Bus[]
  Students        Student[]
  TransportFees   TransportFee[]

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([collegeId])
}

model Bus {
  id              String    @id @default(uuid())
  busNumber       String    @unique
  regNumber       String    @unique
  capacity        Int
  driverName      String
  driverPhone     String
  driverLicense   String?
  conductorName   String?
  conductorPhone  String?
  gpsDeviceId     String?
  status          String    @default("active") // active, maintenance, inactive
  lastServiceDate DateTime?
  nextServiceDate DateTime?

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  routeId         String
  route           BusRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([routeId])
  @@index([collegeId])
}

model TransportFee {
  id              String    @id @default(uuid())
  amount          Float
  frequency       String    @default("monthly")
  dueDate         DateTime?
  discountPercent Float?    @default(0)
  description     String?

  routeId         String
  route           BusRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  collegeId       String
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([routeId])
  @@index([collegeId])
}

// ==================== AUDIT & SECURITY ====================

model AuditLog {
  id              String    @id @default(uuid())
  action          String    // CREATE, UPDATE, DELETE, LOGIN, etc.
  entityType      String    // User, Student, Fee, etc.
  entityId        String
  oldValues       Json?
  newValues       Json?
  ipAddress       String?
  userAgent       String?
  changes         String?

  userId          String?
  user            User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  superAdminId    String?
  superAdmin      SuperAdmin? @relation("SuperAdminAuditLogs", fields: [superAdminId], references: [id], onDelete: SetNull)

  collegeId       String?
  college         College?  @relation(fields: [collegeId], references: [id], onDelete: SetNull)

  createdAt       DateTime  @default(now())

  @@index([collegeId])
  @@index([userId])
  @@index([entityType])
}

model OTPLog {
  id              String    @id @default(uuid())
  otp             String
  purpose         String    // login, verification, password_reset
  isUsed          Boolean   @default(false)
  expiresAt       DateTime
  usedAt          DateTime?
  attempts        Int       @default(0)
  maxAttempts     Int       @default(3)

  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt       DateTime  @default(now())

  @@index([userId])
}
