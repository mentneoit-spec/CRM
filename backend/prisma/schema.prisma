generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SuperAdmin {
  id           String     @id @default(uuid())
  name         String
  email        String     @unique
  password     String
  phone        String?
  twoFAEnabled Boolean    @default(true)
  twoFASecret  String?
  role         String     @default("SuperAdmin")
  lastLogin    DateTime?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  AuditLogs    AuditLog[] @relation("SuperAdminAuditLogs")
}

model CollegeDomain {
  id          String    @id @default(uuid())
  domain      String    @unique
  collegeName String
  isPrimary   Boolean   @default(false)
  status      String    @default("pending")
  sslEnabled  Boolean   @default(false)
  dnsVerified Boolean   @default(false)
  dnsToken    String?
  approvedBy  String?
  approvedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  collegeId   String
  college     College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([collegeId, domain])
}

model College {
  id                        String                     @id @default(uuid())
  name                      String
  description               String?
  email                     String?
  phone                     String?
  address                   String?
  city                      String?
  state                     String?
  country                   String?
  pincode                   String?
  logo                      String?
  favicon                   String?
  theme                     String                     @default("blue")
  footerText                String?
  status                    String                     @default("active")
  whiteLabel                Boolean                    @default(true)
  maxUsers                  Int                        @default(10000)
  storageLimit              Int                        @default(100)
  storageUsed               Int                        @default(0)
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  subscriptionPlan          String                     @default("starter")
  subscriptionStartDate     DateTime?
  subscriptionEndDate       DateTime?
  isSubscriptionActive      Boolean                    @default(true)
  AccountsTeams             AccountsTeam[]
  Admins                    Admin[]
  Admissions                Admission[]
  AdmissionTeams            AdmissionTeam[]
  Attendances               Attendance[]
  AuditLogs                 AuditLog[]
  Buses                     Bus[]
  Routes                    BusRoute[]
  Domains                   CollegeDomain[]
  Complains                 Complain[]
  Exams                     Exam[]
  Results                   ExamResult[]
  Fees                      Fee[]
  Homework                  Homework[]
  Notices                   Notice[]
  Parents                   Parent[]
  Payments                  Payment[]
  Sclasses                  Sclass[]
  Sections                  Section[]
  Students                  Student[]
  Subjects                  Subject[]
  Teachers                  Teacher[]
  TeacherAttendances        TeacherAttendance[]
  TeacherSectionAssignments TeacherSectionAssignment[]
  TransportFees             TransportFee[]
  TransportTeams            TransportTeam[]
  Users                     User[]
  HRManagers                HRManager[]
  Employees                 Employee[]
  EmployeeAttendances       EmployeeAttendance[]
  EmployeeSalaries          EmployeeSalary[]
  EmployeeLeaves            EmployeeLeave[]
}

model Role {
  id          String   @id @default(uuid())
  name        String
  description String?
  permissions Json?    @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model User {
  id                   String         @id @default(uuid())
  name                 String
  email                String?
  phone                String?
  password             String
  profileImage         String?
  role                 String
  roleId               String?
  collegeId            String?
  isEmailVerified      Boolean        @default(false)
  isPhoneVerified      Boolean        @default(false)
  twoFAEnabled         Boolean        @default(false)
  twoFASecret          String?
  tempPassword         String?        // Temporary password (cleared after first login)
  lastLogin            DateTime?
  lastLoginIP          String?
  isActive             Boolean        @default(true)
  isDeleted            Boolean        @default(false)
  metadata             Json?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  AccountsTeamProfile  AccountsTeam?
  AdminProfile         Admin?
  AdmissionTeamProfile AdmissionTeam?
  AuditLogs            AuditLog[]
  OTPLogs              OTPLog[]
  ParentProfile        Parent?
  StudentProfile       Student?
  TeacherProfile       Teacher?
  TransportTeamProfile TransportTeam?
  HRManagerProfile     HRManager?
  college              College?       @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@unique([email, collegeId])
  @@index([collegeId])
  @@index([role])
}

model Admin {
  id           String   @id @default(uuid())
  name         String
  email        String
  password     String
  phone        String?
  profileImage String?
  role         String   @default("Admin")
  designation  String?
  department   String?
  collegeId    String
  userId       String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  college      College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@index([email])
}

model AdmissionTeam {
  id           String      @id @default(uuid())
  name         String
  email        String
  phone        String?
  profileImage String?
  designation  String?
  collegeId    String
  userId       String      @unique
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Admissions   Admission[]
  college      College     @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model AccountsTeam {
  id           String    @id @default(uuid())
  name         String
  email        String
  phone        String?
  profileImage String?
  designation  String?
  collegeId    String
  userId       String    @unique
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  college      College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  Payments     Payment[]

  @@index([collegeId])
}

model TransportTeam {
  id           String   @id @default(uuid())
  name         String
  email        String
  phone        String?
  profileImage String?
  designation  String?
  collegeId    String
  userId       String   @unique
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  college      College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model HRManager {
  id           String     @id @default(uuid())
  name         String
  email        String
  phone        String?
  profileImage String?
  role         String     @default("HR Manager")
  designation  String?
  department   String?    @default("Human Resources")
  collegeId    String
  userId       String     @unique
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  college      College    @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  Employees    Employee[]

  @@index([collegeId])
  @@index([email])
}

model Employee {
  id                   String                @id @default(uuid())
  name                 String
  email                String
  phone                String?
  employeeId           String
  department           String
  designation          String
  dateOfJoining        DateTime?
  dateOfBirth          DateTime?
  gender               String?
  qualification        String?
  experience           Int?
  salary               Float                 @default(0)
  bankAccount          String?
  bankName             String?
  ifscCode             String?
  address              String?
  status               String                @default("Active")
  profileImage         String?
  collegeId            String
  hrManagerId          String
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  Attendances          EmployeeAttendance[]
  SalaryDetails        EmployeeSalary[]
  LeaveRecords         EmployeeLeave[]
  college              College               @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  hrManager            HRManager             @relation(fields: [hrManagerId], references: [id], onDelete: Cascade)

  @@unique([collegeId, employeeId])
  @@index([collegeId])
  @@index([hrManagerId])
  @@index([email])
}

model EmployeeAttendance {
  id          String    @id @default(uuid())
  date        DateTime
  status      String    @default("Present")
  leaveType   String?
  remarks     String?
  employeeId  String
  collegeId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  college     College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, date])
  @@index([employeeId])
  @@index([date])
  @@index([collegeId])
}

model EmployeeSalary {
  id              String    @id @default(uuid())
  month           String
  year            Int
  baseSalary      Float
  allowances      Float     @default(0)
  deductions      Float     @default(0)
  netSalary       Float
  workingDays     Int       @default(30)
  attendedDays    Int       @default(30)
  status          String    @default("Pending")
  remarks         String?
  employeeId      String
  collegeId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  employee        Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@unique([employeeId, month, year])
  @@index([employeeId])
  @@index([collegeId])
  @@index([status])
}

model EmployeeLeave {
  id          String    @id @default(uuid())
  leaveType   String
  startDate   DateTime
  endDate     DateTime
  reason      String?
  status      String    @default("Pending")
  approvedBy  String?
  approvedAt  DateTime?
  employeeId  String
  collegeId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  college     College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  employee    Employee  @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([collegeId])
  @@index([status])
}

model Sclass {
  id                        String                     @id @default(uuid())
  sclassName                String
  sclassCode                String?
  academicYear              String?
  sectionCount              Int                        @default(1)
  description               String?
  collegeId                 String
  classTeacherId            String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  Exams                     Exam[]
  classTeacher              Teacher?                   @relation("ClassTeacher", fields: [classTeacherId], references: [id])
  college                   College                    @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  Sections                  Section[]
  Students                  Student[]
  Subjects                  Subject[]
  TeacherSectionAssignments TeacherSectionAssignment[]

  @@index([collegeId])
}

model Section {
  id                        String                     @id @default(uuid())
  sectionName               String
  capacity                  Int                        @default(60)
  sclassId                  String
  collegeId                 String
  Homework                  Homework[]
  college                   College                    @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  sclass                    Sclass                     @relation(fields: [sclassId], references: [id], onDelete: Cascade)
  Students                  Student[]
  TeacherSectionAssignments TeacherSectionAssignment[]

  @@index([sclassId])
  @@index([collegeId])
}

model Subject {
  id           String       @id @default(uuid())
  subName      String
  subCode      String
  description  String?
  creditHours  Int?
  maxMarks     Int          @default(100)
  passingMarks Int          @default(40)
  collegeId    String
  sclassId     String
  teacherId    String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  Attendances  Attendance[]
  ExamResults  ExamResult[]
  Homeworks    Homework[]
  college      College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  sclass       Sclass       @relation(fields: [sclassId], references: [id], onDelete: Cascade)
  teacher      Teacher?     @relation(fields: [teacherId], references: [id])

  @@unique([collegeId, sclassId, subCode])
  @@index([sclassId])
  @@index([teacherId])
}

model Teacher {
  id                 String                     @id @default(uuid())
  name               String
  email              String
  phone              String?
  password           String
  profileImage       String?
  dateOfBirth        DateTime?
  gender             String?
  qualification      String?
  experience         Int?
  specialization     String?
  employeeId         String?
  salary             Decimal?                   @default(0)
  collegeId          String
  userId             String                     @unique
  isActive           Boolean                    @default(true)
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt
  Complaints         Complain[]
  Homeworks          Homework[]
  ClassTeacherOf     Sclass[]                   @relation("ClassTeacher")
  Subjects           Subject[]
  college            College                    @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  Attendances        TeacherAttendance[]
  SectionAssignments TeacherSectionAssignment[]

  @@index([collegeId])
}

model TeacherSectionAssignment {
  id        String   @id @default(uuid())
  teacherId String
  sclassId  String
  sectionId String
  collegeId String
  createdAt DateTime @default(now())
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  sclass    Sclass   @relation(fields: [sclassId], references: [id], onDelete: Cascade)
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@unique([teacherId, sectionId])
  @@index([teacherId])
  @@index([sclassId])
  @@index([sectionId])
  @@index([collegeId])
}

model TeacherAttendance {
  id        String   @id @default(uuid())
  date      DateTime
  status    String
  leaveType String?
  remarks   String?
  teacherId String
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  teacher   Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([collegeId])
}

model Student {
  id                String       @id @default(uuid())
  name              String
  studentId         String
  rollNum           Int?
  email             String?
  phone             String?
  password          String
  dateOfBirth       DateTime?
  gender            String?
  parentName        String?
  parentPhone       String?
  profileImage      String?
  board             Board?
  integratedCourse  String?
  group             String?
  admissionYear     Int?
  admissionNumber   String?
  customClassName   String?
  customSectionName String?
  collegeId         String
  sclassId          String?
  sectionId         String?
  parentId          String?
  userId            String       @unique
  busRouteId        String?
  isActive          Boolean      @default(true)
  isDeleted         Boolean      @default(false)
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  Attendances       Attendance[]
  Complaints        Complain[]
  ExamResults       ExamResult[]
  Fees              Fee[]
  Payments          Payment[]
  busRoute          BusRoute?    @relation(fields: [busRouteId], references: [id])
  college           College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  parent            Parent?      @relation(fields: [parentId], references: [id])
  sclass            Sclass?      @relation(fields: [sclassId], references: [id], onDelete: Cascade)
  section           Section?     @relation(fields: [sectionId], references: [id])
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([collegeId, studentId])
  @@unique([collegeId, email])
  @@index([sclassId])
  @@index([parentId])
}

model Parent {
  id           String     @id @default(uuid())
  name         String
  email        String?
  phone        String
  password     String
  profileImage String?
  relation     String?
  occupation   String?
  address      String?
  collegeId    String
  userId       String     @unique
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
  Complaints   Complain[]
  college      College    @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  Payments     Payment[]
  Students     Student[]

  @@unique([collegeId, phone])
  @@index([collegeId])
  @@index([phone])
}

model Admission {
  id              String         @id @default(uuid())
  admissionNumber String         @unique
  applicantName   String
  applicantEmail  String
  applicantPhone  String
  dateOfBirth     DateTime?
  gender          String?
  fatherName      String?
  motherName      String?
  address         String?
  previousSchool  String?
  previousGrade   String?
  documents       Json?
  status          String         @default("pending")
  appliedFor      String?
  appliedDate     DateTime       @default(now())
  approvedDate    DateTime?
  rejectionReason String?
  comments        String?
  collegeId       String
  admissionTeamId String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  admissionTeam   AdmissionTeam? @relation(fields: [admissionTeamId], references: [id])
  college         College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
  @@index([status])
}

model Exam {
  id           String       @id @default(uuid())
  examName     String
  examCode     String?
  description  String?
  examType     String       @default("offline")
  totalMarks   Int          @default(100)
  passingMarks Int          @default(40)
  examDate     DateTime?
  startTime    String?
  endTime      String?
  duration     Int?
  isPublished  Boolean      @default(false)
  collegeId    String
  sclassId     String
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  college      College      @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  sclass       Sclass       @relation(fields: [sclassId], references: [id], onDelete: Cascade)
  ExamResults  ExamResult[]

  @@index([collegeId])
  @@index([sclassId])
}

model ExamResult {
  id            String   @id @default(uuid())
  marksObtained Float    @default(0)
  percentage    Float?
  grade         String?
  remarks       String?
  isAbsent      Boolean  @default(false)
  studentId     String
  subjectId     String
  examId        String
  collegeId     String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  college       College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  exam          Exam     @relation(fields: [examId], references: [id], onDelete: Cascade)
  student       Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([studentId, subjectId, examId])
  @@index([studentId])
  @@index([examId])
}

model Attendance {
  id        String   @id @default(uuid())
  date      DateTime
  status    String
  remarks   String?
  studentId String
  subjectId String
  collegeId String
  college   College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student   Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject   Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([subjectId])
  @@index([date])
}

model Notice {
  id            String   @id @default(uuid())
  title         String
  description   String
  details       String?
  category      String?
  priority      String   @default("normal")
  attachments   Json?    @default("[]")
  publishedDate DateTime @default(now())
  collegeId     String
  createdBy     String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  college       College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  @@index([collegeId])
}

model Complain {
  id            String    @id @default(uuid())
  title         String
  description   String
  category      String?
  status        String    @default("pending")
  priority      String    @default("normal")
  attachments   Json?     @default("[]")
  adminResponse String?
  resolvedDate  DateTime?
  studentId     String?
  teacherId     String?
  parentId      String?
  collegeId     String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  college       College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  parent        Parent?   @relation(fields: [parentId], references: [id])
  student       Student?  @relation(fields: [studentId], references: [id])
  teacher       Teacher?  @relation(fields: [teacherId], references: [id])

  @@index([collegeId])
  @@index([status])
}

model Homework {
  id           String   @id @default(uuid())
  title        String
  description  String?
  dueDate      DateTime
  instructions String?
  attachments  Json?     @default("[]")
  totalMarks   Int?
  teacherId    String
  subjectId    String
  sectionId    String?
  collegeId    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  college      College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  section      Section? @relation(fields: [sectionId], references: [id])
  subject      Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  teacher      Teacher  @relation(fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId])
  @@index([subjectId])
  @@index([sectionId])
}

model Fee {
  id          String    @id @default(uuid())
  feeType     String
  feeCategory String?
  amount      Float
  dueDate     DateTime
  frequency   String    @default("yearly")
  description String?
  isActive    Boolean   @default(true)
  studentId   String
  collegeId   String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  college     College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  Payments    Payment[]

  @@index([studentId])
  @@index([collegeId])
}

model Payment {
  id                String        @id @default(uuid())
  transactionId     String        @unique
  paymentMethod     String
  amount            Float
  status            String        @default("pending")
  paymentDate       DateTime?
  receiptNumber     String?
  notes             String?
  studentId         String
  parentId          String?
  feeId             String?
  collegeId         String
  accountsTeamId    String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  accountsTeam      AccountsTeam? @relation(fields: [accountsTeamId], references: [id])
  college           College       @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  fee               Fee?          @relation(fields: [feeId], references: [id])
  parent            Parent?       @relation(fields: [parentId], references: [id])
  student           Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([collegeId])
  @@index([status])
}

model BusRoute {
  id            String         @id @default(uuid())
  routeName     String
  routeNumber   String         @unique
  startPoint    String
  endPoint      String
  distance      Float?
  estimatedTime String?
  stopsCount    Int?
  fee           Float
  description   String?
  isActive      Boolean        @default(true)
  collegeId     String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  Buses         Bus[]
  college       College        @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  Students      Student[]
  TransportFees TransportFee[]

  @@index([collegeId])
}

model Bus {
  id              String    @id @default(uuid())
  busNumber       String    @unique
  regNumber       String    @unique
  capacity        Int
  driverName      String
  driverPhone     String
  driverLicense   String?
  conductorName   String?
  conductorPhone  String?
  gpsDeviceId     String?
  status          String    @default("active")
  lastServiceDate DateTime?
  nextServiceDate DateTime?
  collegeId       String
  routeId         String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  route           BusRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([collegeId])
}

model TransportFee {
  id              String    @id @default(uuid())
  amount          Float
  frequency       String    @default("monthly")
  dueDate         DateTime?
  discountPercent Float?    @default(0)
  description     String?
  routeId         String
  collegeId       String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  college         College   @relation(fields: [collegeId], references: [id], onDelete: Cascade)
  route           BusRoute  @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([collegeId])
}

model AuditLog {
  id           String      @id @default(uuid())
  action       String
  entityType   String
  entityId     String
  oldValues    Json?
  newValues    Json?
  ipAddress    String?
  userAgent    String?
  changes      String?
  userId       String?
  superAdminId String?
  collegeId    String?
  createdAt    DateTime    @default(now())
  college      College?    @relation(fields: [collegeId], references: [id])
  superAdmin   SuperAdmin? @relation("SuperAdminAuditLogs", fields: [superAdminId], references: [id])
  user         User?       @relation(fields: [userId], references: [id])

  @@index([collegeId])
  @@index([userId])
  @@index([entityType])
}

model OTPLog {
  id          String    @id @default(uuid())
  otp         String
  purpose     String
  isUsed      Boolean   @default(false)
  expiresAt   DateTime
  usedAt      DateTime?
  attempts    Int       @default(0)
  maxAttempts Int       @default(3)
  userId      String
  createdAt   DateTime  @default(now())
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

enum Board {
  STATE
  CBSE
  IGCSE
  IB
}
