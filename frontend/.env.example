# Copy to .env for local development
# Base API URL (without /api is ok; the app normalizes it)
# Local dev:
#   REACT_APP_API_URL=http://localhost:5000
# Production (example if backend runs on same server port 5000):
#   REACT_APP_API_URL=http://54.221.37.23:5000
REACT_APP_API_URL=http://localhost:5000
