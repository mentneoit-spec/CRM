{
  "name": "college-erp-backend",
  "version": "1.0.0",
  "description": "Multi-Tenant White-Label College ERP & CRM SaaS Platform - Enterprise-grade backend supporting 1M users",
  "main": "index.js",
  "author": "Mentneo Company",
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "scripts": {
    "dev": "nodemon index.js",
    "start": "node index.js",
    "test": "cross-env NODE_ENV=test jest --coverage --detectOpenHandles",
    "test:watch": "jest --watch",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:studio": "prisma studio",
    "prisma:deploy": "prisma migrate deploy",
    "lint": "eslint .",
    "format": "prettier --write .",
    "setup": "bash setup.sh",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop college-erp",
    "pm2:restart": "pm2 restart college-erp",
    "pm2:logs": "pm2 logs college-erp",
    "pm2:monit": "pm2 monit"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.478.0",
    "@aws-sdk/client-sns": "^3.1010.0",
    "@aws-sdk/s3-request-presigner": "^3.478.0",
    "@prisma/client": "^6.19.2",
    "bcryptjs": "^2.4.3",
    "bull": "^4.12.0",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dotenv": "^16.0.3",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.0",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.7",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "pdfkit": "^0.18.0",
    "pg": "^8.20.0",
    "qrcode": "^1.5.3",
    "razorpay": "^2.9.2",
    "redis": "^4.6.11",
    "speakeasy": "^2.0.0",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^2.0.22",
    "prettier": "^3.1.1",
    "prisma": "^6.19.2",
    "supertest": "^6.3.3"
