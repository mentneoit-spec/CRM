# ==================== DATABASE ====================
# Example format only. Do NOT commit real credentials.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ==================== JWT ====================
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d

# ==================== FRONTEND ====================

# ==================== RAZORPAY (Payment Gateway) ====================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ==================== EMAIL ====================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM=noreply@yourplatform.com

# Note: For Gmail, you need to:
# 1. Enable 2-Factor Authentication on your Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use that App Password here (not your regular Gmail password)

# ==================== AWS (For File Storage) ====================
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_REGION=us-east-1
AWS_S3_BUCKET=your-bucket-name

# ==================== OTP Settings ====================
OTP_EXPIRE_TIME=10  # in minutes
OTP_MAX_ATTEMPTS=3

# ==================== Session ====================
SESSION_SECRET=your-session-secret-key

# ==================== API Rate Limiting ====================
RATE_LIMIT_WINDOW_MS=900000  # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100  # requests per window




# ==================== APP URL ====================
# Public base URL for backend when deployed (optional)
APP_URL=http://localhost:5000

# Base API prefix used by the frontend (if applicable)
API_URL=/api

# ==================== DEFAULT PASSWORDS ====================
# Used by Admin bulk CSV import when the CSV doesn't include a password.
DEFAULT_STUDENT_PASSWORD=Student@123


